# Copy this file to `.env` in the same folder (`part2/.env`) and fill in your key.
# Do not commit real keys — `.env` is gitignored.

# Gemini (required for dashboard OCR, pipeline CLI, API POST /ingest)
GEMINI_API_KEY=
# or:
# GOOGLE_API_KEY=

GEMINI_MODEL=gemini-flash-latest

# Optional: fail faster on stage Wi‑Fi (fewer retries, shorter HTTP wait)
# GEMINI_QUICK=1
# GEMINI_HTTP_TIMEOUT_MS=90000

# Optional — local API without Docker
# MQTT_MERGE_URL=http://127.0.0.1:8000
